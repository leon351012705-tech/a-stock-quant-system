# 复制此文件为 .env 并填上你自己的 key
# cp .env.example .env

# ============== 数据接口 ==============
TUSHARE_TOKEN=your_tushare_token_here

# ============== 推送渠道 ==============
# 任选一个或都填。两个都填会同时推。两个都不填则控制台打印。

# 渠道 1：Server酱（微信）
SERVERCHAN_KEY=your_serverchan_key_here

# 渠道 2：邮箱（SMTP）
# 重要：邮箱密码不能填登录密码，必须用"授权码 / app password"
#   QQ 邮箱：邮箱设置 → 账户 → 开启 SMTP 服务 → 拿到授权码
#   163 邮箱：设置 → POP3/SMTP/IMAP → 开启 → 拿到授权码
#   Gmail：账户 → 安全 → 两步验证 → 应用专用密码
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_FROM=youraccount@qq.com
EMAIL_PASSWORD=your_smtp_authorization_code_here
EMAIL_TO=youraccount@qq.com
# EMAIL_TO 支持多个收件人，用英文逗号分隔：a@x.com,b@y.com
